# Pinata IPFS — get your JWT from https://app.pinata.cloud/developers/api-keys
REACT_APP_PINATA_JWT=your_pinata_jwt_here

# Public Pinata gateway for fetching IPFS content
REACT_APP_INFURA_DEDICATED_GATEWAY=https://gateway.pinata.cloud

# Optional: AES encryption key for medical records (defaults to built-in key if omitted)
REACT_APP_ENCRYPTION_SECRET=your_custom_secret_here